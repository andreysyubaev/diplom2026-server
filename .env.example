# Скопируй этот файл в .env и заполни своими значениями.
# Никогда не коммить настоящий .env в git!

# Сервер
PORT=8080
HOST=0.0.0.0

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=college_app
DB_USER=college_user
DB_PASSWORD=college_pass
DB_SSL=false

# JWT - ОБЯЗАТЕЛЬНО смени на свой длинный случайный секрет в продакшене!
# Сгенерировать можно командой: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_string_in_production_min_32_chars
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# Первый админ - создаётся автоматически при первом запуске сервера, если ещё нет ни одного админа
INITIAL_ADMIN_EMAIL=admin@college.local
INITIAL_ADMIN_PASSWORD=admin12345
INITIAL_ADMIN_NAME=Главный администратор

# Папка для хранения загруженных файлов (картинок к конспектам/тестам)
UPLOADS_DIR=uploads

# Длительность жизни кода входа в предмет (минут)
SUBJECT_CODE_TTL_MINUTES=5
